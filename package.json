{
  "name": "evochia-site",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test",
    "test:watch": "node --test --watch",
    "preview": "node scripts/preview-server.mjs",
    "lint:js": "eslint js scripts tests middleware.ts playwright.config.mjs",
    "lint:css": "stylelint \"css/site.css\" \"css/cookieconsent-evochia.css\"",
    "lint:html": "html-validate \"*.html\" \"en/**/*.html\" \"el/**/*.html\"",
    "qa:lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "qa:repo": "node --test tests/site-quality.test.mjs tests/site-http.test.mjs",
    "qa:browser": "npx playwright test",
    "qa:browser:update": "npx playwright test tests/playwright/visual.spec.mjs --update-snapshots",
    "qa:browser:install": "npx playwright install webkit",
    "qa:browser:install:all": "npx playwright install chromium firefox webkit",
    "qa:lighthouse:mobile": "node scripts/run-lighthouse.mjs mobile",
    "qa:lighthouse:desktop": "node scripts/run-lighthouse.mjs desktop",
    "qa:lhci:local:mobile": "node scripts/run-lhci.mjs local mobile",
    "qa:lhci:local:desktop": "node scripts/run-lhci.mjs local desktop",
    "qa:lhci:local": "npm run qa:lhci:local:mobile && npm run qa:lhci:local:desktop",
    "qa:lhci:live:mobile": "node scripts/run-lhci.mjs live mobile",
    "qa:lhci:live:desktop": "node scripts/run-lhci.mjs live desktop",
    "qa:lhci:live": "npm run qa:lhci:live:mobile && npm run qa:lhci:live:desktop",
    "qa:pa11y": "node scripts/run-pa11y.mjs",
    "qa:vnu": "node scripts/run-vnu.mjs",
    "qa:seo:rules": "node scripts/check-seo-rules.mjs",
    "qa:hreflang:local": "node scripts/check-hreflang.mjs local",
    "qa:hreflang:live": "node scripts/check-hreflang.mjs live",
    "qa:structured-data:local": "node scripts/check-structured-data.mjs local",
    "qa:structured-data:live": "node scripts/check-structured-data.mjs live",
    "qa:links": "node scripts/check-links.mjs",
    "qa:headers": "node scripts/check-security-headers.mjs",
    "qa:crux": "node scripts/check-crux.mjs",
    "qa:gsc": "node scripts/check-search-console.mjs",
    "qa:summary:pass1": "node scripts/summarize-reports.mjs pass1",
    "qa:summary:pass2": "node scripts/summarize-reports.mjs pass2",
    "qa:pass1": "node scripts/run-pass.mjs pass1",
    "qa:pass2": "node scripts/run-pass.mjs pass2",
    "qa:pagespeed": "node scripts/run-pagespeed.mjs",
    "qa:zap": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-zap-baseline.ps1",
    "qa:local": "npm run qa:lint && npm run qa:repo && npm run qa:browser && npm run qa:lighthouse:mobile && npm run qa:lighthouse:desktop",
    "qa:browserstack": "node scripts/run-browserstack.mjs local",
    "qa:browserstack:public": "node scripts/run-browserstack.mjs public"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "browserstack-node-sdk": "^1.50.2",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "html-validate": "^10.11.1",
    "pa11y-ci": "^4.0.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vnu-jar": "^25.8.1"
  },
  "dependencies": {
    "chrome-launcher": "^0.14.2",
    "lighthouse-logger": "^1.2.0",
    "yargs-parser": "^13.1.2"
  }
}
